      <Association Name="Status_Film" Member="Status" ThisKey="IdStatus" OtherKey="IdStatus" Type="Status" IsForeignKey="true" />
      <Association Name="Zanr_Film" Member="Zanr" ThisKey="IdZanr" OtherKey="IdZanr" Type="Zanr" IsForeignKey="true" />
    </Type>
  </Table>
  <Table Name="dbo.Recenzija" Member="Recenzijas">
    <Type Name="Recenzija">
