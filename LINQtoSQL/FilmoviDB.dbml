  <Table Name="dbo.Film" Member="Films">
    <Type Name="Film">
      <Column Name="IdFilm" Type="System.Int32" DbType="Int NOT NULL IDENTITY" IsPrimaryKey="true" IsDbGenerated="true" CanBeNull="false" />
      <Column Name="Naziv" Type="System.String" DbType="NVarChar(200) NOT NULL" CanBeNull="false" />
      <Column Name="DatumGledanja" Type="System.DateTime" DbType="Date NOT NULL" CanBeNull="false" />
      <Column Name="IdZanr" Type="System.Int32" DbType="Int NOT NULL" CanBeNull="false" />
      <Column Name="IdStatus" Type="System.Int32" DbType="Int NOT NULL" CanBeNull="false" />
